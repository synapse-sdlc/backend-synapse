SYNAPSE_PROVIDER=ollama
SYNAPSE_MODEL=qwen3:8b
SYNAPSE_BEDROCK_MODEL=us.anthropic.claude-sonnet-4-6
BEDROCK_MODEL_FAST=us.anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_MODEL_BALANCED=us.anthropic.claude-sonnet-4-6
BEDROCK_MODEL_POWERFUL=us.anthropic.claude-opus-4-6
AWS_DEFAULT_REGION=us-west-1

DATABASE_URL=postgresql+asyncpg://synapse:synapse@localhost:5433/synapse
DATABASE_URL_SYNC=postgresql://synapse:synapse@localhost:5433/synapse
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Vector Store — "chromadb" (default, local) or "qdrant" (remote)
VECTOR_STORE_PROVIDER=chromadb
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Sentry error monitoring (optional — leave empty to disable)
# Get your DSN at https://sentry.io
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# Bedrock Guardrails (optional — get ID from Terraform output bedrock_guardrail_id)
BEDROCK_GUARDRAIL_ID=
BEDROCK_GUARDRAIL_VERSION=DRAFT
